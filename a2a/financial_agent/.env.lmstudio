# LM Studio OpenAI-compatible endpoint (default port 1234)
LLM_API_BASE=http://localhost:1234/v1
LLM_MODEL=qwen/qwen3-30b-a3b-2507
LLM_API_KEY=not-needed

# Finance MCP tool (local). Agent defaults match these; omit from .env if unchanged.
MCP_URL=http://localhost:8000/mcp
MCP_TRANSPORT=streamable_http

# When finance tool uses 8000, run the agent on 8001 (same machine)
PORT=8001

# MLflow (local SQLite store — avoids deprecated ./mlruns file-store warning)
MLFLOW_TRACKING_URI=sqlite:///./mlflow.db
MLFLOW_EXPERIMENT_NAME=financial-agent
# Set to 0/false to disable LangChain trace autolog (e.g. noisy async warnings on A2A server)
# MLFLOW_LANGCHAIN_LOG_TRACES=false
